# Template for boilerplate .gitignore files
# For usage with ignore-git.sh
# By Jack Semancik

# macOS autogenerated files
.DS_Store

#Hide files autogenerated by Vim (swap files and backup files)
*.swp
*.swo
.*.swo
*.un~
*.*~
*~

# node.js/vite/Shopify boilerplate
node_modules


/.cache
/build
/app/build
/public/build/
/public/_dev
/app/public/build
/prisma/dev.sqlite
/prisma/dev.sqlite-journal
database.sqlite

# Environmental Processes
.env
.env.*

# Ignore compiled/built/bundled files
/extensions/*/dist

# Ignore shopify files created during app dev
.shopify/*
.shopify.lock

# Hide files auto-generated by react router

.react-router/

